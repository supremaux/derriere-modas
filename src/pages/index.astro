    <!-- INTERACTIVE SCRIPTS -->
    <script>
      // Toast notification helper
      function showToast(message, type = "success") {
        const container = document.getElementById("toast-container");
        if (!container) return;

        const toast = document.createElement("div");
        toast.className = `flex items-center justify-between gap-4 bg-neutral-900 border border-pink-900/40 p-4 rounded-2xl shadow-2xl transform translate-y-5 opacity-0 transition-all duration-300 border-l-4 ${type === "success" ? "border-l-pink-500" : "border-l-amber-500"}`;

        toast.innerHTML = `
          <div class="flex items-center gap-3">
            <span class="flex-shrink-0 w-2 h-2 rounded-full ${type === "success" ? "bg-pink-500" : "bg-amber-500"}"></span>
            <p class="text-xs text-neutral-100 font-medium">${message}</p>
          </div>
          <button class="text-neutral-500 hover:text-white transition-colors duration-200">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
          </button>
        `;

        container.appendChild(toast);

        // Animate slide-in
        setTimeout(() => {
          toast.classList.remove("translate-y-5", "opacity-0");
        }, 10);

        // Remove trigger
        const closeBtn = toast.querySelector("button");
        closeBtn?.addEventListener("click", () => {
          toast.classList.add("translate-y-5", "opacity-0");
          setTimeout(() => toast.remove(), 300);
        });

        // Auto remove
        setTimeout(() => {
          if (toast.parentNode) {
            toast.classList.add("translate-y-5", "opacity-0");
            setTimeout(() => toast.remove(), 300);
          }
        }, 4000);
      }

      // 1. Header scroll effect
      window.addEventListener("scroll", () => {
        const header = document.getElementById("main-header");
        if (!header) return;
        if (window.scrollY > 50) {
          header.classList.add(
            "bg-neutral-950/85",
            "backdrop-blur-md",
            "border-neutral-900",
            "shadow-[0_4px_30px_rgba(0,0,0,0.5)]",
          );
          header.classList.remove("h-24");
          header.classList.add("h-20");
        } else {
          header.classList.remove(
            "bg-neutral-950/85",
            "backdrop-blur-md",
            "border-neutral-900",
            "shadow-[0_4px_30px_rgba(0,0,0,0.5)]",
          );
          header.classList.remove("h-20");
          header.classList.add("h-24");
        }
      });

      // 2. Mobile Menu Toggle
      const mobileToggle = document.getElementById("mobile-menu-toggle");
      const mobileMenu = document.getElementById("mobile-menu");
      const iconOpen = document.getElementById("menu-icon-open");
      const iconClose = document.getElementById("menu-icon-close");

      if (mobileToggle && mobileMenu) {
        mobileToggle.addEventListener("click", () => {
          const isOpen = !mobileMenu.classList.contains("hidden");
          if (isOpen) {
            mobileMenu.classList.add("hidden");
            iconOpen?.classList.remove("hidden");
            iconClose?.classList.add("hidden");
          } else {
            mobileMenu.classList.remove("hidden");
            iconOpen?.classList.add("hidden");
            iconClose?.classList.remove("hidden");
          }
        });
      }

      // Close mobile menu when links are clicked
      document.querySelectorAll(".mobile-link").forEach((link) => {
        link.addEventListener("click", () => {
          mobileMenu?.classList.add("hidden");
          iconOpen?.classList.remove("hidden");
          iconClose?.classList.add("hidden");
        });
      });

      // 3. Collection Filter logic
      const tabs = document.querySelectorAll(".filter-tab");
      const items = document.querySelectorAll(".collection-item");

      tabs.forEach((tab) => {
        tab.addEventListener("click", () => {
          tabs.forEach((t) => {
            t.classList.remove("active", "text-pink-400", "border-pink-500");
            t.classList.add("text-neutral-400", "border-transparent");
          });

          tab.classList.add("active", "text-pink-400", "border-pink-500");
          tab.classList.remove("text-neutral-400", "border-transparent");

          const category = tab.getAttribute("data-category");

          items.forEach((item) => {
            const itemCat = item.getAttribute("data-category");
            if (category === "all" || itemCat === category) {
              item.style.display = "flex";
              setTimeout(() => {
                item.style.opacity = "1";
                item.style.transform = "translateY(0)";
              }, 50);
            } else {
              item.style.opacity = "0";
              item.style.transform = "translateY(15px)";
              setTimeout(() => {
                item.style.display = "none";
              }, 300);
            }
          });
        });
      });

      // 4. Shopping Bag Simulator
      let bagCount = 0;
      const bagCountBadge = document.getElementById("bag-count");
      const bagButtons = document.querySelectorAll(".add-to-bag-btn");

      bagButtons.forEach((btn) => {
        btn.addEventListener("click", (e) => {
          e.preventDefault();
          const itemName = btn.getAttribute("data-item");
          bagCount++;
          if (bagCountBadge) {
            bagCountBadge.textContent = bagCount.toString();
            bagCountBadge.classList.add("scale-125");
            setTimeout(() => bagCountBadge.classList.remove("scale-125"), 200);
          }
          showToast(
            `"${itemName}" adicionado ao seu atendimento personalizado.`,
          );
        });
      });

      // 5. Interactive Atelier Customizer
      const swatchButtons = document.querySelectorAll(".swatch-btn");
      const customizerImg = document.getElementById("customizer-img");
      const colorLabel = document.getElementById("color-label");
      const activeTitle = document.getElementById("dress-active-title");
      const activeDesc = document.getElementById("dress-active-desc");
      const activeId = document.getElementById("dress-id");

      swatchButtons.forEach((swatch) => {
        swatch.addEventListener("click", () => {
          swatchButtons.forEach((s) => {
            s.classList.remove("active", "border-pink-500");
            s.classList.add("border-transparent");
          });

          swatch.classList.add("active", "border-pink-500");
          swatch.classList.remove("border-transparent");

          // Extract values
          const colorName = swatch.getAttribute("data-color");
          const imageUrl = swatch.getAttribute("data-img");
          const dressIdStr = swatch.getAttribute("data-id");
          const titleStr = swatch.getAttribute("data-title");
          const descStr = swatch.getAttribute("data-desc");

          // Apply changes smoothly
          if (customizerImg) {
            customizerImg.style.opacity = "0.3";
            setTimeout(() => {
              customizerImg.setAttribute("src", imageUrl);
              customizerImg.style.opacity = "1";
            }, 300);
          }

          if (colorLabel) colorLabel.textContent = colorName;
          if (activeTitle) activeTitle.textContent = titleStr;
          if (activeDesc) activeDesc.textContent = descStr;
          if (activeId) activeId.textContent = dressIdStr;

          showToast(`Tonalidade alterada para: ${colorName}`);
        });
      });

      // Saving Custom dress creation
      const addCustomBtn = document.getElementById("add-custom-btn");
      if (addCustomBtn) {
        addCustomBtn.addEventListener("click", () => {
          const currentTitle = activeTitle
            ? activeTitle.textContent
            : "Criação Exclusiva";
          bagCount++;
          if (bagCountBadge) {
            bagCountBadge.textContent = bagCount.toString();
          }
          showToast(
            `Sua criação "${currentTitle}" foi salva no seu dossiê de compras.`,
          );
        });
      }

      // Custom Stylist button
      const customConsultBtn = document.getElementById("custom-consulting-btn");
      if (customConsultBtn) {
        customConsultBtn.addEventListener("click", () => {
          openBookingModal();
          showToast("Abertura da agenda do estilista responsável.", "success");
        });
      }

      // 6. Size Calculator Guide (Couture Fit)
      const sizeForm = document.getElementById("size-calc-form");
      const sizeResultBox = document.getElementById("size-result");
      const recommendedSizeTxt = document.getElementById("recommended-size");

      if (sizeForm) {
        sizeForm.addEventListener("submit", (e) => {
          e.preventDefault();
          const bustVal =
            parseInt(
              (document.getElementById("bust-input") as HTMLInputElement).value,
            ) || 88;
          const waistVal =
            parseInt(
              (document.getElementById("waist-input") as HTMLInputElement)
                .value,
            ) || 68;
          const hipsVal =
            parseInt(
              (document.getElementById("hips-input") as HTMLInputElement).value,
            ) || 98;

          // Simple logic simulating French high-luxury sizes
          let size = 38;
          if (waistVal < 64 && bustVal < 84) {
            size = 34;
          } else if (waistVal < 68 && bustVal < 88) {
            size = 36;
          } else if (waistVal < 72 && bustVal < 92) {
            size = 38;
          } else if (waistVal < 76 && bustVal < 96) {
            size = 40;
          } else if (waistVal < 82 && bustVal < 102) {
            size = 42;
          } else {
            size = 44;
          }

          if (recommendedSizeTxt) {
            recommendedSizeTxt.textContent = `Derriere ${size} (FR)`;
          }

          if (sizeResultBox) {
            sizeResultBox.classList.remove("hidden");
            // Smooth scroll to the result
            sizeResultBox.scrollIntoView({
              behavior: "smooth",
              block: "nearest",
            });
          }

          showToast(
            "Tamanho calculado de acordo com sua modelagem de luxo.",
            "success",
          );
        });
      }

      // Size Confirm and Book
      const sizeBookBtn = document.getElementById("size-book-btn");
      if (sizeBookBtn) {
        sizeBookBtn.addEventListener("click", () => {
          openBookingModal();
        });
      }

      // 7. VIP Atelier Booking Modal Controls
      const bookingModal = document.getElementById("booking-modal");
      const openBookingBtn = document.getElementById("open-booking-btn");
      const openBookingBtnMobile = document.getElementById(
        "open-booking-btn-mobile",
      );
      const closeBookingBtn = document.getElementById("close-booking-btn");
      const bookingForm = document.getElementById("booking-form");

      function openBookingModal() {
        if (bookingModal) {
          bookingModal.classList.remove("hidden");
          document.body.style.overflow = "hidden"; // Stop scrolling
        }
      }

      function closeBookingModal() {
        if (bookingModal) {
          bookingModal.classList.add("hidden");
          document.body.style.overflow = ""; // Re-enable scrolling
        }
      }

      if (openBookingBtn)
        openBookingBtn.addEventListener("click", openBookingModal);
      if (openBookingBtnMobile)
        openBookingBtnMobile.addEventListener("click", openBookingModal);
      if (closeBookingBtn)
        closeBookingBtn.addEventListener("click", closeBookingModal);

      // Close modal on outer clicks
      if (bookingModal) {
        bookingModal.addEventListener("click", (e) => {
          if (e.target === bookingModal) {
            closeBookingModal();
          }
        });
      }

      // Booking Submit
      if (bookingForm) {
        bookingForm.addEventListener("submit", (e) => {
          e.preventDefault();
          const nameVal = (
            document.getElementById("book-name") as HTMLInputElement
          ).value;
          const dateVal = (
            document.getElementById("book-date") as HTMLInputElement
          ).value;
          const timeVal = (
            document.getElementById("book-time") as HTMLSelectElement
          ).value;

          closeBookingModal();
          bookingForm.reset();

          showToast(
            `Sua experiência de alto luxo está reservada! Aguarde nossa concierge.`,
            "success",
          );

          // Show full alert modal simulation via modern toast
          setTimeout(() => {
            showToast(
              `Atelier VIP: ${nameVal}, te aguardamos dia ${dateVal} às ${timeVal}.`,
              "success",
            );
          }, 1500);
        });
      }

      // 8. Newsletter & Bag trigger alerts
      const newsForm = document.getElementById("newsletter-form");
      if (newsForm) {
        newsForm.addEventListener("submit", (e) => {
          e.preventDefault();
          newsForm.reset();
          showToast(
            "Parabéns! Você acaba de adentrar ao círculo secreto de elegância Derriere.",
            "success",
          );
        });
      }

      const bagBtn = document.getElementById("bag-btn");
      if (bagBtn) {
        bagBtn.addEventListener("click", () => {
          if (bagCount === 0) {
            showToast(
              "Sua sacola de atendimento está vazia no momento.",
              "info",
            );
          } else {
            showToast(
              `Você possui ${bagCount} vestidos agendados para a sua consultoria privada.`,
              "success",
            );
          }
        });
      }

      // 9. Reveal Elements on Scroll
      const revealElements = document.querySelectorAll(".reveal");
      const revealOnScroll = () => {
        const windowHeight = window.innerHeight;
        revealElements.forEach((el) => {
          const elementTop = el.getBoundingClientRect().top;
          const elementVisible = 150;
          if (elementTop < windowHeight - elementVisible) {
            el.classList.add("active");
          }
        });
      };
      window.addEventListener("scroll", revealOnScroll);
      window.addEventListener("load", revealOnScroll);
    </script>
